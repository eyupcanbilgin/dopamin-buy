# Doply local development example.
# Do not commit real Vercel, Neon, or admin secrets.

# local | staging | production
DOPLY_DEPLOY_ENV=local

# Local PostgreSQL or a Neon development/staging branch URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Required for /api/admin/* routes. Use a long random value per environment.
DOPLY_ADMIN_KEY=replace-with-a-long-random-local-admin-key

# Local: http://localhost:3000
# Staging Preview: https://staging.doply.app or the current Vercel preview URL
# Production: https://doply.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Placeholder for future premium no-ads mode.
NEXT_PUBLIC_DOPLY_PREMIUM_NO_ADS=false

# Manual catalog seed defaults. Run only against local or staging DBs.
DOPLY_SEED_PRODUCT_COUNT=10000
DOPLY_SEED_VALUE=doply-staging-2026

# Database verification minimums.
DOPLY_VERIFY_MIN_PRODUCTS=10000
DOPLY_VERIFY_MIN_CATEGORIES=12
DOPLY_VERIFY_MIN_BRANDS=1000
DOPLY_VERIFY_MIN_IMAGES=10000

# Production seed reset is blocked unless both values below are set explicitly.
# Leave these unset for normal local/staging work.
# DOPLY_ALLOW_PRODUCTION_SEED=true
# DOPLY_SEED_CONFIRM=production-reset
