# PostgreSQL connection used by Prisma on staging/production.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/doply?schema=public"

# Required for /api/admin/* routes. Use a long random value in staging.
DOPLY_ADMIN_KEY="replace-with-a-long-random-staging-key"

# Public canonical URL used by metadata, robots.txt, sitemap.xml, and OpenGraph.
NEXT_PUBLIC_SITE_URL="https://doply.app"

# Placeholder for future premium no-ads mode.
NEXT_PUBLIC_DOPLY_PREMIUM_NO_ADS="false"
